{
    "name": "shipeasy/php-entity-guide-example",
    "type": "project",
    "description": "A single-page Laravel 11 'entity guide' for the Shipeasy PHP SDK. The SDK is NOT wired yet — every value is a placeholder.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "shipeasy/shipeasy": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "audit": {
            "abandoned": "report"
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
