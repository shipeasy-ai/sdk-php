APP_NAME="Shipeasy PHP Entity Guide"
APP_ENV=local
# Leave APP_KEY empty after `cp .env.example .env`, then run:
#   php artisan key:generate
# to populate it. The framework will not boot without a key.
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Caches/sessions/views use file/array drivers — NO database is required.
LOG_CHANNEL=stack
SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

# ---------------------------------------------------------------------------
# Shipeasy SDK — NOT wired yet. After `composer require shipeasy/shipeasy`,
# set your server key here and read it in routes/web.php via env():
#
#   SHIPEASY_SERVER_KEY=sk_server_xxx
# ---------------------------------------------------------------------------
