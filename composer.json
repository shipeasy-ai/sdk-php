{
    "name": "shipeasy/shipeasy",
    "description": "Shipeasy server SDK for PHP \u2014 flags, configs, experiments, metrics.",
    "type": "library",
    "license": "MIT",
    "version": "0.10.0",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "open-feature/sdk": "^2.0"
    },
    "suggest": {
        "open-feature/sdk": "Use Shipeasy as an OpenFeature provider via Shipeasy\\OpenFeature\\ShipeasyProvider (install open-feature/sdk ^2.0)."
    },
    "autoload": {
        "psr-4": {
            "Shipeasy\\": "src/Shipeasy/"
        },
        "files": [
            "src/Shipeasy/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Shipeasy\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/shipeasy-skill"
    ],
    "scripts": {
        "test": "phpunit",
        "gen-readme": "php scripts/gen-readme.php"
    }
}
