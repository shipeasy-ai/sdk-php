{
  "name": "shipeasy/shipeasy",
  "description": "Shipeasy server SDK for PHP — flags, configs, experiments, metrics.",
  "type": "library",
  "license": "MIT",
  "version": "0.1.0",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {"Shipeasy\\": "src/Shipeasy/"}
  },
  "autoload-dev": {
    "psr-4": {"Shipeasy\\Tests\\": "tests/"}
  }
}
